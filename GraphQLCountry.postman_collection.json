    {
      "name": "Fetch all languages",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const languages = json.data.languages;\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Languages array is not empty\", function () {\r",
              "    pm.expect(languages.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each language has code, name and native\", function () {\r",
              "    languages.forEach(lang => {\r",
              "        pm.expect(lang.code).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(lang.name).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(lang.native).to.be.a(\"string\").and.not.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"RTL field is a boolean\", function () {\r",
              "    languages.forEach(lang => {\r",
              "        pm.expect(lang.rtl).to.be.a(\"boolean\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Known languages are present\", function () {\r",
              "    const codes = languages.map(l => l.code);\r",
              "    [\"en\", \"hi\", \"ar\", \"zh\"].forEach(code => {\r",
              "        pm.expect(codes).to.include(code);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Arabic is marked as RTL\", function () {\r",
              "    const arabic = languages.find(l => l.code === \"ar\");\r",
              "    pm.expect(arabic.rtl).to.be.true;\r",
              "});"
            ],
