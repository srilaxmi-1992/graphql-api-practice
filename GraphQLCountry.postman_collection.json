    {
      "name": "Fetch all Continents",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const continents = json.data.continents;\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Continents array is not empty\", function () {\r",
              "    pm.expect(continents.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Returns exactly 7 continents\", function () {\r",
              "    pm.expect(continents.length).to.eql(7);\r",
              "});\r",
              "\r",
              "pm.test(\"Each continent has name and code\", function () {\r",
              "    continents.forEach(continent => {\r",
              "        pm.expect(continent.name).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(continent.code).to.be.a(\"string\").and.not.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Continent codes are 2 characters long\", function () {\r",
              "    continents.forEach(continent => {\r",
              "        pm.expect(continent.code.length).to.eql(2);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Expected continents are present\", function () {\r",
              "    const codes = continents.map(c => c.code);\r",
              "    [\"AF\", \"AN\", \"AS\", \"EU\", \"NA\", \"OC\", \"SA\"].forEach(code => {\r",
              "        pm.expect(codes).to.include(code);\r",
              "    });\r",
              "});"
            ],
