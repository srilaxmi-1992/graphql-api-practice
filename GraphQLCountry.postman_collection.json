    {
      "name": "Fetch specific country",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const country = json.data.country;\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Country data exists\", function () {\r",
              "    pm.expect(country).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"Country has at least one language\", function () {\r",
              "    pm.expect(country.languages).to.be.an(\"array\");\r",
              "    pm.expect(country.languages.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each language has name and code\", function () {\r",
              "    country.languages.forEach(lang => {\r",
              "        pm.expect(lang.name).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(lang.code).to.be.a(\"string\").and.not.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Continent name exists\", function () {\r",
              "    pm.expect(country.continent.name).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Country belongs to Asia continent\", function () {\r",
              "    pm.expect(country.continent.name).to.eql(\"Asia\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
