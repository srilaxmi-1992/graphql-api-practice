    {
      "name": "GetCountriesByCodes",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const countries = json.data.countries;\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Returns exactly 2 countries\", function () {\r",
              "    pm.expect(countries.length).to.eql(2);\r",
              "});\r",
              "\r",
              "pm.test(\"Each country has name, code and capital\", function () {\r",
              "    countries.forEach(country => {\r",
              "        pm.expect(country.name).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(country.code).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(country.capital).to.be.a(\"string\").and.not.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Returned codes match requested codes IN and US\", function () {\r",
              "    const codes = countries.map(c => c.code);\r",
              "    pm.expect(codes).to.have.members([\"IN\", \"US\"]);\r",
              "});\r",
              "\r",
              "pm.test(\"India has correct capital\", function () {\r",
              "    const india = countries.find(c => c.code === \"IN\");\r",
              "    pm.expect(india.capital).to.eql(\"New Delhi\");\r",
              "});\r",
              "\r",
              "pm.test(\"USA has correct capital\", function () {\r",
              "    const usa = countries.find(c => c.code === \"US\");\r",
              "    pm.expect(usa.capital).to.eql(\"Washington D.C.\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query GetCountriesByCodes($code1 : String!, $code2 :String!){\r\n    countries(filter : { code : { in : [$code1, $code2]}})\r\n    {\r\n        name\r\n        code\r\n        capital\r\n    }\r\n}",
            "variables": "{\r\n    \"code1\": \"IN\",\r\n    \"code2\": \"US\"\r\n}"
