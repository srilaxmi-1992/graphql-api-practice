  "item": [
    {
      "name": "Fetch all countries",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const countries = json.data.countries;\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Countries array is not empty\", function () {\r",
              "    pm.expect(countries.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each country has name, code, capital and currency\", function () {\r",
              "    countries.forEach(country => {\r",
              "        pm.expect(country.name).to.be.a(\"string\").and.not.empty;\r",
              "        pm.expect(country.code).to.be.a(\"string\").and.not.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Country codes are 2 characters long\", function () {\r",
              "    countries.forEach(country => {\r",
              "        pm.expect(country.code.length).to.eql(2);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\r\n    countries{\r\n        name\r\n        code\r\n        name\r\n        capital\r\n        currency\r\n    }\r\n}",
            "variables": ""
          }
        },
        "url": {
          "raw": "https://countries.trevorblades.com/",
          "protocol": "https",
          "host": [
            "countries",
            "trevorblades",
            "com"
          ],
          "path": [
            ""
          ]
        }
      },
      "response": []
