  "item": [
    {
      "name": "Fetch page 1 characters",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.data).to.not.include(\"errors\");\r",
              "});\r",
              "\r",
              "pm.test(\"results array is not empty\", function () {\r",
              "    pm.expect(json.data.characters.results.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"results array has exactly 20 items\", function () {\r",
              "    pm.expect(json.data.characters.results.length).to.be.eql(20);\r",
              "});\r",
              "\r",
              "pm.test(\"results array has exactly 20 items\", function () {\r",
              "    let resArr = json.data.characters.results;\r",
              "    resArr.forEach(result => {\r",
              "        pm.expect(result.id).to.be.not.null;\r",
              "        pm.expect(result.name).to.be.not.null;\r",
              "        pm.expect(result.status).to.be.not.null;\r",
              "        pm.expect(result.species).to.be.not.null;\r",
              "    }\r",
              "    )\r",
              "});\r",
              "\r",
              "pm.test(\"results array has exactly 20 items\", function () {\r",
              "    let info = json.data.characters.info;\r",
              "    \r",
              "        pm.expect(info.pages).to.be.above(0);\r",
              "        pm.expect(info.next).to.be.eq(2);\r",
              "        pm.expect(info.prev).to.be.null;\r",
              "  \r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query Fetchpage1character($page:Int!) {\r\ncharacters(page: $page)\r\n{\r\nresults {\r\n    id\r\n    name\r\n    status\r\n    species\r\n}\r\ninfo {\r\n    count\r\n    pages\r\n    next\r\n    prev\r\n}\r\n}\r\n\r\n}",
            "variables": "{\r\n    \"page\" : 1\r\n}"
          }
        },
        "url": {
          "raw": "https://rickandmortyapi.com/graphql",
          "protocol": "https",
          "host": [
            "rickandmortyapi",
            "com"
          ],
          "path": [
            "graphql"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Fetch Single character",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const character = json.data.character;\r",
              "\r",
              "\r",
              "// Test 1 — HTTP status\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Test 2 — No GraphQL errors ✅ FIXED\r",
              "pm.test(\"Response has no errors field\", function () {\r",
              "    pm.expect(json.errors).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"character.name equals\", function () {\r",
              "    pm.expect(character.name).to.be.equals(\"Rick Sanchez\");\r",
              "    pm.expect(character.status).to.be.equals(\"Alive\");\r",
              "    pm.expect(character.gender).to.be.equals(\"Male\");\r",
              "    pm.expect(character.origin.name).to.exist;\r",
              "    pm.expect(character.origin.name).to.not.empty;\r",
              "    pm.expect(character.origin.name).to.be.a(\"string\");\r",
              "    pm.expect(character.location.name).to.exist;\r",
              "    pm.expect(character.location.name).to.not.empty;\r",
              "    pm.expect(character.location.name).to.be.a(\"string\");\r",
              "    pm.collectionVariables.set(\"character_name\", character.name);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query FetchSingleCharacter($id:ID!) {\r\n    character(id:$id){\r\n        name\r\n        gender\r\n        status\r\n        origin {\r\n            name\r\n            dimension\r\n        }\r\n        location {\r\n            name\r\n        }\r\n\r\n    }\r\n}",
            "variables": "{\r\n    \"id\":1\r\n}"
          }
        },
        "url": {
          "raw": "https://rickandmortyapi.com/graphql",
          "protocol": "https",
          "host": [
            "rickandmortyapi",
            "com"
          ],
          "path": [
            "graphql"
          ]
        }
      },
      "response": []
    },
